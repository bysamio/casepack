# ─── CasePack Self-Host Configuration ────────────────────────────
# Copy this file to .env and fill in your values.
# Required fields are marked with (required).
# Run ./activate.sh after filling in this file.

# ── CasePack Version ─────────────────────────────────────────────
CASEPACK_API_VERSION=0.28.0
CASEPACK_SPA_VERSION=0.26.0

# ── Database ─────────────────────────────────────────────────────
DB_NAME=casepack
DB_USER=casepack
DB_PASS=                          # (required) PostgreSQL password
DB_PORT=5432

# ── Keycloak ─────────────────────────────────────────────────────
KC_DB_NAME=keycloak
KC_DB_USER=keycloak
KC_DB_PASS=                       # (required) Keycloak DB password
KC_ADMIN_USER=admin
KC_ADMIN_PASS=                    # (required) Keycloak admin password
KEYCLOAK_PORT=8081
KEYCLOAK_HOSTNAME=http://localhost:8081  # Set to your auth URL for production

# ── S3 / SeaweedFS ───────────────────────────────────────────────
# The bundled SeaweedFS path uses non-empty local credentials.
# For external S3 backends, set endpoint + credentials:
S3_ACCESS_KEY=admin
S3_SECRET_KEY=admin123456
S3_BUCKET=casepack
S3_REGION=us-east-1
S3_PORT=8333
# Optional. Keep the default internal endpoint for server-only S3 access.
S3_ENDPOINT=http://seaweedfs:8333
# Optional. Browser-facing endpoint used for presigned evidence upload/download URLs.
# Leave blank to sign with S3_ENDPOINT. For local Docker, this hostname routes to the
# host-published SeaweedFS port while the API still uses S3_ENDPOINT internally.
S3_PUBLIC_ENDPOINT=http://casepack-s3.localhost:${S3_PORT}

# ── API ──────────────────────────────────────────────────────────
API_PORT=8080
CORS_ORIGINS=http://localhost:3000
GOTENBERG_URL=http://gotenberg:3000
JAVA_OPTS=-Xms256m -Xmx512m

# ── SPA ──────────────────────────────────────────────────────────
SPA_PORT=3000
API_URL=http://localhost:8080
OIDC_AUTHORITY=http://localhost:8081/realms/casepack

# ── OIDC (auto-wired to bundled Keycloak by default) ─────────────
# Override these if using external Keycloak:
# OIDC_ISSUER_URI=https://auth.example.com/realms/casepack
# OIDC_JWK_SET_URI=https://auth.example.com/realms/casepack/protocol/openid-connect/certs

# ── License and bootstrap (set by activate.sh — do not edit manually) ─
CASEPACK_DEPLOYMENT_MODE=self_host
CASEPACK_INSTALLATION_ID=
CASEPACK_LICENSE_TOKEN_FILE=/run/secrets/license.jwt
CASEPACK_LICENSE_KEY_SOURCE=jwks
CASEPACK_LICENSE_PUBLIC_KEY=
CASEPACK_LICENSE_JWKS_URL=
CASEPACK_ACTIVATION_FILE=/run/secrets/activation.json
CASEPACK_SELF_HOST_BOOTSTRAP_ENABLED=true
CASEPACK_SELF_HOST_BOOTSTRAP_TENANT_NAME=CasePack Workspace
CASEPACK_SELF_HOST_BOOTSTRAP_ADMIN_EMAIL=
CASEPACK_SELF_HOST_BOOTSTRAP_ADMIN_INITIAL_PASSWORD=

# ── Keycloak Admin API (optional; enables bootstrap/user invites) ───
CASEPACK_KEYCLOAK_BASE_URL=http://keycloak:8080
CASEPACK_KEYCLOAK_REALM=casepack
CASEPACK_KEYCLOAK_SPA_CLIENT_ID=casepack-spa
CASEPACK_KEYCLOAK_SPA_REDIRECT_URI=http://localhost:3000/auth/callback
CASEPACK_KEYCLOAK_SA_CLIENT_ID=casepack-user-manager
CASEPACK_KEYCLOAK_SA_CLIENT_SECRET=casepack-user-manager-secret

# ── Licensing operations ──────────────────────────────────────────
LICENSING_API_URL=https://licensing.bysam.io
LICENSING_PORTAL_URL=https://licensing.bysam.io/portal
