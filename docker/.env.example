# ─── CasePack Self-Host Configuration ────────────────────────────
# Copy this file to .env and fill in your values.
# Required fields are marked with (required).

# ── CasePack Version ─────────────────────────────────────────────
CASEPACK_VERSION=0.3.1
# CASEPACK_SPA_VERSION=latest

# ── Database ─────────────────────────────────────────────────────
DB_NAME=casepack
DB_USER=casepack
DB_PASS=                          # (required) PostgreSQL password
DB_PORT=5432

# ── Keycloak ─────────────────────────────────────────────────────
KC_DB_NAME=keycloak
KC_DB_USER=keycloak
KC_DB_PASS=                       # (required) Keycloak DB password
KC_ADMIN_USER=admin
KC_ADMIN_PASS=                    # (required) Keycloak admin password
KEYCLOAK_PORT=8081
KEYCLOAK_HOSTNAME=localhost:8081  # Set to your domain for production

# ── MinIO / S3 ───────────────────────────────────────────────────
S3_ACCESS_KEY=                    # (required) MinIO root user
S3_SECRET_KEY=                    # (required) MinIO root password
S3_BUCKET=casepack
S3_REGION=us-east-1
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# ── API ──────────────────────────────────────────────────────────
API_PORT=8080
CORS_ORIGINS=http://localhost:5173
SWAGGER_PUBLIC=false
JAVA_OPTS=-Xms256m -Xmx512m

# ── OIDC (auto-wired to bundled Keycloak by default) ─────────────
# Override these if using external Keycloak:
# OIDC_ISSUER_URI=https://auth.example.com/realms/casepack
# OIDC_JWK_SET_URI=https://auth.example.com/realms/casepack/protocol/openid-connect/certs

# ── License (optional — blank = Starter/free plan) ───────────────
CASEPACK_LICENSE_TOKEN=
CASEPACK_LICENSE_PUBLIC_KEY=

# ── SPA (uncomment when SPA is available) ────────────────────────
# SPA_PORT=3000
# API_URL=http://localhost:8080
# OIDC_AUTHORITY=http://localhost:8081/realms/casepack
